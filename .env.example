# MongoDB Connection String Template
MONGODB_URI=

# Database Name
MONGODB_DB_NAME=

# Admin Login Credentials
# Change these to secure values in production
ADMIN_USERNAME=
ADMIN_PASSWORD=

# JWT Secret Key
# Generate a strong random string (min 32 characters)
# Use: openssl rand -base64 32
JWT_SECRET=

# ImageKit Configuration
# Get these from https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
